{
  "name": "@seanmozeik/gist",
  "version": "0.0.1",
  "description": "Link → clean text → summary.",
  "bin": {
    "gist": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/chmod-bin.mjs",
    "check": "bun run typecheck",
    "clean": "rimraf dist",
    "dev:cli": "bun src/cli.ts",
    "s": "bun src/cli.ts",
    "gist": "bun src/cli.ts",
    "test": "bun run vitest run",
    "test:coverage": "bun run vitest run --coverage",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.70.2",
    "@mozilla/readability": "^0.6.0",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "es-toolkit": "^1.46.1",
    "file-type": "^22.0.1",
    "gpt-tokenizer": "^3.4.0",
    "jsdom": "^29.1.0",
    "json5": "^2.2.3",
    "markdansi": "^0.2.1",
    "mime": "^4.1.0",
    "ora": "^9.4.0",
    "osc-progress": "^0.3.0",
    "sanitize-html": "^2.17.3",
    "tokentally": "^0.1.1",
    "tslog": "^4.10.2"
  },
  "devDependencies": {
    "@effect/language-service": "^0.85.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/coverage-v8": "^4.1.5",
    "bun-types": "1.3.13",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "uuid": "14.0.0",
    "vite": "8.0.10"
  },
  "engines": {
    "bun": ">=1.0",
    "node": ">=22"
  }
}
