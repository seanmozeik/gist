{
  "name": "@seanmozeik/gist",
  "version": "0.0.1",
  "workspaces": ["packages/*", "apps/*"],
  "description": "Link → clean text → summary.",
  "bin": {
    "summarize": "./dist/cli.js",
    "summarizer": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/esm/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js"
    },
    "./content": {
      "types": "./dist/types/content/index.d.ts",
      "import": "./dist/esm/content/index.js"
    },
    "./prompts": {
      "types": "./dist/types/prompts/index.d.ts",
      "import": "./dist/esm/prompts/index.js"
    }
  },
  "scripts": {
    "build": "bun run clean && cd packages/core && bun run build && bun run build:lib && bun run build:cli",
    "build:bun": "bun scripts/build-bun.js",
    "build:bun:test": "bun scripts/build-bun.js --test",
    "build:cli": "bun scripts/build-cli.mjs",
    "build:lib": "tsc -p tsconfig.build.json",
    "check": "bun run format:check && bun run lint && bun run test:coverage",
    "clean": "rimraf dist packages/core/dist",
    "dev:cli": "cd packages/core && bun run build && bun src/cli.ts",
    "docs:list": "bun scripts/docs-list.ts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --tsconfig tsconfig.oxlint.json --config .oxlintrc.json .",
    "lint:fix": "oxlint --tsconfig tsconfig.oxlint.json --config .oxlintrc.json --fix . && bun run format",
    "prepare": "bun run build",
    "release": "bash scripts/release.sh",
    "s": "bun src/cli.ts",
    "summarize": "bun src/cli.ts",
    "test": "bun run vitest run",
    "test:coverage": "bun run vitest run --coverage",
    "test:coverage:build": "bun run build && bun run test:coverage",
    "test:extension-e2e": "cd apps/chrome-extension && bun run test:e2e",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.70.2",
    "@seanmozeik/gist-core": "workspace:*",
    "commander": "^14.0.3",
    "file-type": "^22.0.1",
    "gpt-tokenizer": "^3.4.0",
    "json5": "^2.2.3",
    "markdansi": "^0.2.1",
    "mime": "^4.1.0",
    "ora": "^9.4.0",
    "osc-progress": "^0.3.0",
    "tokentally": "^0.1.1",
    "tslog": "^4.10.2"
  },
  "devDependencies": {
    "@effect/language-service": "^0.85.1",
    "@fal-ai/client": "^1.10.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/coverage-v8": "^4.1.5",
    "bun-types": "1.3.13",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "uuid": "14.0.0",
    "vite": "8.0.10"
  },
  "engines": {
    "bun": ">=1.0",
    "node": ">=22"
  },
  "patchedDependencies": {
    "@zag-js/preact@1.40.0": "patches/@zag-js__preact@1.40.0.patch"
  }
}
